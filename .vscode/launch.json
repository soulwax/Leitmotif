{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Leitmotif: debug (Rust shell + dev server)",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "args": ["build", "--manifest-path=./src-tauri/Cargo.toml", "--no-default-features"]
      },
      "program": "${workspaceFolder}/src-tauri/target/debug/leitmotif.exe",
      "cwd": "${workspaceFolder}",
      "env": {
        "CHOREO_BIN": "${workspaceFolder}/../../target/debug/choreo.exe"
      },
      "preLaunchTask": "leitmotif: build choreo (dependency)",
      "sourceLanguages": ["rust"],
      "presentation": {
        "group": "leitmotif",
        "order": 1
      }
    },
    {
      "name": "Leitmotif: debug (Windows/MSVC)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/src-tauri/target/debug/leitmotif.exe",
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "CHOREO_BIN",
          "value": "${workspaceFolder}/../../target/debug/choreo.exe"
        }
      ],
      "preLaunchTask": "leitmotif: build choreo (dependency)",
      "presentation": {
        "group": "leitmotif",
        "order": 2
      }
    }
  ]
}
